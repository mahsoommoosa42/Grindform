{
  "name": "@grindform/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build ./src/client/main.ts --outdir ./public/app --target=browser --minify",
    "build:client": "bun build ./src/client/main.ts --outdir ./public/app --target=browser --minify",
    "dev": "bun run build:client && bun --watch run src/server.ts",
    "start": "bun run src/server.ts",
    "serve": "bun run src/server.ts",
    "test": "echo 'web is verified via the Playwright e2e suite (bun run test:e2e)'",
    "test:coverage": "echo 'web is verified via the Playwright e2e suite (bun run test:e2e)'",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@grindform/api": "workspace:*",
    "@grindform/auth": "workspace:*",
    "@grindform/core": "workspace:*",
    "@grindform/db": "workspace:*",
    "@electric-sql/pglite": "0.2.14",
    "drizzle-orm": "0.36.4",
    "hono": "4.6.14",
    "lit": "3.2.1"
  },
  "devDependencies": {
    "@playwright/test": "1.49.1",
    "@types/node": "22.10.2",
    "typescript": "5.7.2"
  }
}
