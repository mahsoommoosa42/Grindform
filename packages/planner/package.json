{
  "name": "@grindform/planner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./generate": "./src/generate.ts",
    "./profiles": "./src/profiles.ts"
  },
  "scripts": {
    "build": "echo 'source-only package; no build step'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@grindform/core": "workspace:*",
    "@grindform/catalog": "workspace:*"
  },
  "devDependencies": {
    "typescript": "5.7.2",
    "vitest": "2.1.8",
    "@vitest/coverage-v8": "2.1.8"
  }
}
