{
  "name": "grindform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "test:coverage": "bun run --filter '*' test:coverage",
    "test:e2e": "bun run --filter '@grindform/web' test:e2e",
    "typecheck": "tsc --noEmit",
    "lint": "eslint packages",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,js,json,md}\"",
    "dev": "bun run --filter '@grindform/web' dev",
    "start": "bun run --filter '@grindform/web' start",
    "py:lint": "cd tools/python && uv run ruff check ../..",
    "py:lint:fix": "cd tools/python && uv run ruff check --fix ../..",
    "py:format": "cd tools/python && uv run ruff format ../..",
    "py:format:check": "cd tools/python && uv run ruff format --check ../..",
    "py:precommit": "cd tools/python && uv run pre-commit run --all-files"
  },
  "devDependencies": {
    "typescript": "5.7.2",
    "vitest": "2.1.8",
    "@vitest/coverage-v8": "2.1.8",
    "eslint": "9.17.0",
    "@typescript-eslint/eslint-plugin": "8.18.2",
    "@typescript-eslint/parser": "8.18.2",
    "prettier": "3.4.2",
    "@types/node": "22.10.2"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
